# Boubyan Dental Accounting — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/boubyan
JWT_SECRET=your-very-long-random-secret-here
API_SECRET=
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=Admin@2026
ADMIN_DEFAULT_EMAIL=admin@boubyan.com
ADMIN_DEFAULT_FULLNAME=مدير النظام
ADMIN_RESET_PASSWORD=false
ANTHROPIC_API_KEY=sk-ant-...
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
REPORT_EMAIL=reports@boubyan.com
