# ===== Boubyan Accounting — environment template =====
# Copy to .env and fill in.  cp .env.example .env

# --- Server ---
PORT=3000
NODE_ENV=development

# --- MongoDB ---
MONGO_URI=mongodb://127.0.0.1:27017/boubyan_accounting

# --- Auth / security ---
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
ADMIN_DEFAULT_PASSWORD=Admin@2026
API_SECRET=

# --- CORS ---
ALLOWED_ORIGINS=

# --- Anthropic (AI features / Telegram AI commands) ---
ANTHROPIC_API_KEY=

# --- Telegram ---
# Bot token set via app UI (stored in DB), not here.
TG_CHAT_ID=
TG_ALLOWED_CHATS=
