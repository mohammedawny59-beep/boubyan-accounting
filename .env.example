# ===== Boubyan Accounting — environment template =====
# Copy to .env and fill in.  cp .env.example .env

# --- Server ---
PORT=3000
NODE_ENV=production

# --- MongoDB ---
MONGO_URI=mongodb://127.0.0.1:27017/boubyan_accounting

# --- Auth / security ---
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
# Admin seeded on first boot when no users exist (or when ADMIN_RESET_PASSWORD=true)
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_EMAIL=admin@boubyan.com
ADMIN_DEFAULT_PASSWORD=Admin@2026
ADMIN_DEFAULT_FULLNAME=مدير النظام
# Set to true once to reset admin password from env, then remove or set false
ADMIN_RESET_PASSWORD=false
# Optional M2M key — browser login uses JWT; leave blank unless you call the API from scripts
API_SECRET=

# --- CORS ---
ALLOWED_ORIGINS=https://boubyan-accounting.onrender.com

# --- Anthropic (AI features / Telegram AI commands) ---
ANTHROPIC_API_KEY=

# --- Telegram ---
# Bot token set via app UI (stored in DB), not here.
TG_CHAT_ID=
TG_ALLOWED_CHATS=
